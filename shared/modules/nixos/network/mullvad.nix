#=====================================================================#
# MULLVAD VPN CONFIGURATION
#=====================================================================#
{pkgs, ...}: {
  #--------------------------------------------------------------------#
  #-- Mullvad VPN Service
  #--------------------------------------------------------------------#
  services.mullvad-vpn = {
    enable = true;
    package = pkgs.mullvad-vpn;
  };

  #--------------------------------------------------------------------#
  #-- Mullvad GUI Dependencies
  #--------------------------------------------------------------------#
  environment.systemPackages = with pkgs; [
    libglvnd # OpenGL library (required for Mullvad VPN GUI)
  ];
}
