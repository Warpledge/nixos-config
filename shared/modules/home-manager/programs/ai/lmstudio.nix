#=====================================================================#
# LM STUDIO - LOCAL LLM RUNNER
#=====================================================================#
{
  lib,
  pkgs,
  hostConfig,
  ...
}: {
  config = lib.mkIf hostConfig.lmstudio.enable {
    #--------------------------------------------------------------------#
    #-- Package Installation
    #--------------------------------------------------------------------#
    home.packages = with pkgs; [
      lmstudio
    ];
  };
}
